# ══════════════════════════════════════════════════════════════════════════════
# SpaksTrip — Next.js app (client/) environment reference
# Copy to .env.local and fill in real values. Never commit .env.local.
#
# Enumerated from every `process.env.*` read in client/src (grep-verified).
# REQUIRED vars are validated at server startup by src/lib/env.ts (zod) —
# the app refuses to boot and names the missing/malformed var.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core (REQUIRED) ───────────────────────────────────────────────────────────
# Base origin of the Express API (server/). Origin only — no path, no /health.
# Local dev: http://localhost:4000   Production: https://api.spakstrip.com
NEXT_PUBLIC_API_BASE=http://localhost:4000
# Apex domain for subdomain (white-label agent) resolution in middleware.ts.
# Local dev: localhost  (agents at <slug>.localhost:3000)   Prod: spakstrip.com
NEXT_PUBLIC_APEX_DOMAIN=localhost

# ── Data mode ─────────────────────────────────────────────────────────────────
# "tbo" = live TBO B2B API calls; "mock" = generated data (default when unset).
NEXT_PUBLIC_API_MODE=mock

# ── MongoDB (hotel booking persistence, customer bookings) ────────────────────
# MONGO_URI is preferred; MONGODB_URI is the legacy alias (either works).
MONGO_URI=mongodb://localhost:27017
# Optional explicit DB name (defaults to the one embedded in the URI).
MONGODB_DB_NAME=

# ── TBO Air API (flights) ─────────────────────────────────────────────────────
# Three hosts; flip cert↔prod via these vars only. Fallbacks in
# src/lib/adapters/tbo/auth.ts are the PRODUCTION hosts.
TBO_SHARED_API_URL=https://api.travelboutiqueonline.com/SharedAPI
TBO_AIR_API_URL=https://tboapi.travelboutiqueonline.com
TBO_BOOK_API_URL=https://booking.travelboutiqueonline.com
# Hotel host override (legacy Air-account hotel API; rarely changed).
TBO_HOTEL_API_URL=https://api.tektravels.com
TBO_CLIENT_ID=ApiIntegrationNew
TBO_AIR_USERNAME=your_username
# NOTE: TBO_AIR_PASSWORD is currently NOT read — the live password is hardcoded
# in src/lib/adapters/tbo/auth.ts (deploy-host env mangling of '#'/'$' chars).
# If the password contains '#' or '$', single-quote it: TBO_AIR_PASSWORD='p@ss#w$'
TBO_AIR_PASSWORD=your_password
# Client IP forwarded to TBO (they whitelist by IP).
TBO_END_USER_IP=1.1.1.1
# "true" enables verbose TBO request/response logging.
TBO_DEBUG=false
# Directory where certification-run artifacts are written (scripts only).
TBO_CERTIFICATION_DIR=

# ── TBO egress proxy toggles (route TBO calls via the Express server) ─────────
# "true" proxies the vertical's TBO calls through NEXT_PUBLIC_API_BASE (static IP).
TBO_PROXY_FLIGHTS=false
TBO_PROXY_HOTELS=false

# ── TBOHolidays (hotels) ──────────────────────────────────────────────────────
# Static-data APIs (CountryList, CityList, HotelDetails…) — shared public test creds.
TBO_HOLIDAYS_STATIC_USER_NAME=TBOStaticAPITest
TBO_HOLIDAYS_STATIC_PASSWORD=your_static_password
# Booking APIs (HotelSearch, PreBook, Book) — your agency credentials.
TBO_HOLIDAYS_USER_NAME=your_agency_user
TBO_HOLIDAYS_PASSWORD=your_agency_password
# Optional separate B2B credential pair (falls back to the agency pair).
TBO_HOLIDAYS_B2B_USER_NAME=
TBO_HOLIDAYS_B2B_PASSWORD=
TBO_HOLIDAYS_SEARCH_URL=https://affiliate.tektravels.com/HotelAPI
TBO_HOLIDAYS_BOOK_URL=https://HotelBE.tektravels.com/hotelservice.svc/rest/book
TBO_HOLIDAYS_BOOKING_URL=https://hotelbe.tektravels.com/hotelservice.svc/rest/Getbookingdetail
TBO_HOLIDAYS_HOTEL_API_URL=https://api.tbotechnology.in/TBOHolidays_HotelAPI

# ── TBO Insurance ─────────────────────────────────────────────────────────────
TBO_INSURANCE_AUTH_URL=
TBO_INSURANCE_SEARCH_URL=
TBO_INSURANCE_BOOK_URL=
TBO_INSURANCE_USERNAME=
TBO_INSURANCE_API_PASSWORD=
TBO_INSURANCE_SERVER_IP=

# ── Razorpay payments ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Same key id, exposed to the browser for Checkout.js.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ── Pricing / internal-call security ──────────────────────────────────────────
# HMAC secret binding FareQuote → create-order amounts. MUST be identical to the
# Express server's PRICE_TOKEN_SECRET or cross-layer tokens fail to verify.
PRICE_TOKEN_SECRET=
# Shared token for server-to-server internal API calls (record-booking etc.).
INTERNAL_API_TOKEN=
# Distinct from INTERNAL_API_TOKEN above (that one guards this Next.js app's
# own /api/hotels/book route). This one is sent BY this app TO the Express
# server's /api/internal/* router (agent-config, record-booking, …) — must be
# identical to that server's INTERNAL_API_SECRET. Unset = header omitted,
# matching Express's no-op default (existing behavior unchanged).
INTERNAL_API_SECRET=

# ── SMTP (booking confirmation emails from Next API routes) ───────────────────
# Leave EMAIL_HOST unset to fall back to console logging (dev/CI).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=SpaksTrip <noreply@spakstrip.com>

# ── Maps / geocoding ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GEOAPIFY_KEY=your_geoapify_key
