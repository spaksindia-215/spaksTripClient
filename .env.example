NEXT_PUBLIC_API_MODE=tbo     #tbo for production # mock for dummy data.

# ── TBO Air API — PRODUCTION endpoints ────────────────────────────────────────
# Three hosts: Shared (auth) / Air search / Booking. Flip cert↔prod by these vars only.
#   Shared (Authenticate) — base only; code appends /SharedData.svc/rest/Authenticate
TBO_SHARED_API_URL=https://api.travelboutiqueonline.com/SharedAPI
#   Air search host: Search, FareRule, FareQuote, SSR, Calendar Fare, Price RBD
TBO_AIR_API_URL=https://tboapi.travelboutiqueonline.com
#   Booking host: Book, Ticket, GetBookingDetails, Send/GetChangeRequest, ReleasePNR
TBO_BOOK_API_URL=https://booking.travelboutiqueonline.com
# Legacy base (hotel fallback derivation only; air/book/shared use the explicit vars above)
TBO_API_URL=http://api.tektravels.com
# ClientId issued by TBO for the production environment (cert default is ApiIntegrationNew).
# Read in auth.ts via process.env.TBO_CLIENT_ID — set the live value here.
TBO_CLIENT_ID=tboprod
TBO_AIR_USERNAME=DELS1280
# Live API password (from TBO 17-Jun-2026 email). This is the API password, NOT the TBO portal password.
# Single-quoted so dotenv doesn't treat the '#' as an inline comment (would truncate to "Sp@k").
TBO_AIR_PASSWORD='Sp@k#12D$'
TBO_END_USER_IP=152.55.177.102
